# ============================================================================
# ENVIRONMENT CONFIGURATION - Copy to .env.local and update values
# ============================================================================

# ============================================================================
# APPLICATION SETTINGS
# ============================================================================
NODE_ENV=development
PORT=3000
APP_NAME=diamond-packet-sas
APP_VERSION=1.0.0

# ============================================================================
# DATABASE
# ============================================================================
DATABASE_URL=postgresql://diamond_packet_db:Test@123@localhost:5432/diamond_packet_db
DATABASE_POOL_SIZE=10

# ============================================================================
# JWT CONFIGURATION
# ============================================================================
JWT_SECRET=your-super-secret-jwt-key-min-32-chars-required-here
JWT_REFRESH_SECRET=your-super-secret-refresh-jwt-key-min-32-chars-required-here
JWT_EXPIRES_IN=900s
JWT_REFRESH_EXPIRES_IN=7d

# ============================================================================
# AUTHENTICATION & SECURITY
# ============================================================================
BCRYPT_SALT_ROUNDS=12
CORS_ORIGIN=http://localhost:5173,http://localhost:3000
SESSION_SECRET=your-session-secret-here

# ============================================================================
# RATE LIMITING
# ============================================================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ============================================================================
# EMAIL CONFIGURATION (optional)
# ============================================================================
EMAIL_PROVIDER=smtp
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-email-password
SMTP_FROM=noreply@diamondpacket.com

# ============================================================================
# LOGGING
# ============================================================================
LOG_LEVEL=info
LOG_FILE_PATH=./logs
LOG_MAX_FILE_SIZE=10m
LOG_MAX_FILES=14

# ============================================================================
# AWS CONFIGURATION (optional, for file storage)
# ============================================================================
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-key
AWS_SECRET_ACCESS_KEY=your-aws-secret
AWS_S3_BUCKET=diamond-packet-files