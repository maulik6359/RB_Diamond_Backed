{
  "name": "diamond-packet-saas-backend",
  "version": "1.0.0",
  "description": "Production-ready Diamond Packet Management System SaaS backend",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "tsc && node dist/index.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write 'src/**/*.ts'",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx src/database/seeds/seed.ts",
    "db:generate": "drizzle-kit generate"
  },
  "dependencies": {
    "@paralleldrive/cuid2": "^3.3.0",
    "bcrypt": "latest",
    "cors": "latest",
    "dotenv": "latest",
    "drizzle-orm": "latest",
    "express": "latest",
    "express-rate-limit": "latest",
    "helmet": "latest",
    "joi": "latest",
    "jsonwebtoken": "latest",
    "pg": "latest",
    "uuid": "latest",
    "winston": "latest"
  },
  "devDependencies": {
    "@types/bcrypt": "latest",
    "@types/cors": "^2.8.19",
    "@types/express": "latest",
    "@types/jsonwebtoken": "latest",
    "@types/node": "latest",
    "@types/pg": "^8.16.0",
    "@typescript-eslint/eslint-plugin": "latest",
    "@typescript-eslint/parser": "latest",
    "drizzle-kit": "latest",
    "eslint": "latest",
    "prettier": "latest",
    "tsx": "latest",
    "typescript": "latest"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}